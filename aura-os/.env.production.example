# AURA OS — Production Environment
# Copy this file to .env.production and fill in ALL values
# NEVER commit .env.production to Git

# Application
NODE_ENV=production
PORT=4000
FRONTEND_URL=https://your-domain.com

# Database (REQUIRED — must be strong)
DB_USERNAME=aura
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD
DB_NAME=aura_os

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# JWT (REQUIRED — must be ≥32 chars, generate with: openssl rand -hex 32)
JWT_SECRET=CHANGE_ME_32_CHAR_MIN_SECRET
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d
JWT_OTP_EXPIRATION=600

# Email (SMTP)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password
EMAIL_FROM="AURA OS <noreply@your-domain.com>"

# Twilio (SMS & WhatsApp)
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_FROM_NUMBER=+1234567890
TWILIO_WHATSAPP_NUMBER=+1234567890

# OpenRouter / AI
OPENROUTER_API_KEY=sk-or-v1-CHANGE_ME
OPENROUTER_MODEL=openrouter/owl-alpha

# S3 / MinIO
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=aura
S3_SECRET_ACCESS_KEY=CHANGE_ME_STRONG_PASSWORD
S3_BUCKET=aura-os

# Elasticsearch
ELASTICSEARCH_NODE=http://localhost:9200

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:4000/api
