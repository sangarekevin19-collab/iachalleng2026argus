# AURA OS Environment Configuration
# Copy this file to .env.local and fill in the values

# Application
NODE_ENV=development
PORT=4000
FRONTEND_URL=http://localhost:3000

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=aura
DB_PASSWORD=aura_password
DB_NAME=aura_os
DB_SCHEMA=public
DB_SYNCHRONIZE=false
DB_LOGGING=true
DB_SSL=false

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d
JWT_OTP_EXPIRATION=600

# Email (SMTP)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password
EMAIL_FROM=AURA OS <noreply@auraos.africa>

# Twilio (SMS & WhatsApp)
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_FROM_NUMBER=+1234567890
TWILIO_WHATSAPP_NUMBER=+1234567890

# OpenAI
OPENAI_API_KEY=sk-your-openai-key
OPENAI_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# S3 / MinIO
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=aura
S3_SECRET_ACCESS_KEY=aura_password
S3_BUCKET=aura-os

# Elasticsearch
ELASTICSEARCH_NODE=http://localhost:9200
ELASTICSEARCH_USERNAME=
ELASTICSEARCH_PASSWORD=

# n8n Automation
N8N_URL=http://localhost:5678
N8N_API_KEY=your-n8n-api-key
N8N_CALLBACK_URL=http://localhost:5678
N8N_DEFAULT_TIMEOUT=30000
N8N_MAX_RETRIES=3

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:4000/api
