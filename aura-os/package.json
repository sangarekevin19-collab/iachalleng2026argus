{
  "name": "aura-os",
  "version": "0.1.0",
  "private": true,
  "description": "AURA OS - African Unified Reasoning Assistant Operating System",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean && rm -rf node_modules"
  },
  "devDependencies": {
    "turbo": "^2.3.0",
    "typescript": "^5.6.0"
  },
  "packageManager": "npm@10.0.0",
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@types/passport": "^1.0.17",
    "passport": "^0.7.0",
    "prom-client": "^15.1.3"
  }
}
