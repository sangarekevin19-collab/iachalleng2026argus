{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "title": "🤖 Active Agents",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "aura_active_agents", "legendFormat": "Agents" }
      ],
      "options": { "colorMode": "value", "graphMode": "area", "justifyMode": "center" }
    },
    {
      "title": "✅ Tasks Completed (24h)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "increase(aura_agent_tasks_completed_total[24h])", "legendFormat": "Tasks" }
      ],
      "fieldConfig": { "defaults": { "color": { "mode": "fixed", "fixedColor": "green" } } },
      "options": { "colorMode": "value", "graphMode": "none", "justifyMode": "center" }
    },
    {
      "title": "💰 OpenAI Tokens Used (24h)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "increase(aura_openai_tokens_total[24h])", "legendFormat": "Tokens" }
      ],
      "fieldConfig": { "defaults": { "unit": "short" } },
      "options": { "colorMode": "value", "graphMode": "none", "justifyMode": "center" }
    },
    {
      "title": "💵 API Cost (USD)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "increase(aura_openai_cost_usd_total[24h])", "legendFormat": "24h" },
        { "expr": "increase(aura_openai_cost_usd_total[7d])", "legendFormat": "7d" }
      ],
      "fieldConfig": { "defaults": { "unit": "currencyUSD", "decimals": 4 } },
      "options": { "colorMode": "value", "graphMode": "area", "justifyMode": "center" }
    },
    {
      "title": "📊 Tasks by Agent",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "rate(aura_agent_tasks_completed_total[5m])", "legendFormat": "{{agent}}" }
      ],
      "fieldConfig": {
        "defaults": { "custom": { "drawStyle": "bars", "fillOpacity": 60 } }
      }
    },
    {
      "title": "🧠 Token Usage by Agent",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "rate(aura_openai_tokens_total[5m])", "legendFormat": "{{agent}} - {{type}}" }
      ],
      "fieldConfig": {
        "defaults": { "custom": { "drawStyle": "line", "fillOpacity": 15 } }
      }
    },
    {
      "title": "⏱️ Agent Response Time",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "histogram_quantile(0.95, rate(aura_agent_response_duration_seconds_bucket[5m]))", "legendFormat": "p95 {{agent}}" },
        { "expr": "histogram_quantile(0.50, rate(aura_agent_response_duration_seconds_bucket[5m]))", "legendFormat": "p50 {{agent}}" }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "title": "📋 Agent Leaderboard",
      "type": "table",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum by(agent) (increase(aura_agent_tasks_completed_total[24h]))",
          "legendFormat": "{{agent}}",
          "format": "table",
          "instant": true
        },
        {
          "expr": "sum by(agent) (increase(aura_openai_cost_usd_total[24h]))",
          "legendFormat": "{{agent}}",
          "format": "table",
          "instant": true
        }
      ],
      "transformations": [
        { "id": "merge", "options": {} },
        { "id": "organize", "options": { "renameByName": { "Value #A": "Tasks", "Value #B": "Cost (USD)" } } }
      ]
    }
  ],
  "refresh": "10s",
  "schemaVersion": 38,
  "style": "dark",
  "tags": ["aura-os", "agents", "ai"],
  "templating": { "list": [] },
  "time": { "from": "now-24h", "to": "now" },
  "timepicker": { "refresh_intervals": ["5s", "10s", "30s", "1m"] },
  "timezone": "Europe/Paris",
  "title": "AURA OS — AI Agents",
  "uid": "aura-agents",
  "version": 1
}
