{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "title": "📊 Total Executions",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "increase(aura_workflow_executions_total[24h])", "legendFormat": "24h" }
      ],
      "options": { "colorMode": "value", "graphMode": "area", "justifyMode": "center" }
    },
    {
      "title": "✅ Successful",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "increase(aura_workflow_success_total[24h])", "legendFormat": "24h" }
      ],
      "fieldConfig": { "defaults": { "color": { "mode": "fixed", "fixedColor": "green" } } },
      "options": { "colorMode": "value", "graphMode": "none", "justifyMode": "center" }
    },
    {
      "title": "❌ Failed",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "increase(aura_workflow_errors_total[24h])", "legendFormat": "24h" }
      ],
      "fieldConfig": { "defaults": { "color": { "mode": "fixed", "fixedColor": "red" } } },
      "options": { "colorMode": "value", "graphMode": "none", "justifyMode": "center" }
    },
    {
      "title": "⏱️ Avg Duration",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "rate(aura_workflow_duration_seconds_sum[5m]) / rate(aura_workflow_duration_seconds_count[5m])", "legendFormat": "avg" }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } },
      "options": { "colorMode": "value", "graphMode": "none", "justifyMode": "center" }
    },
    {
      "title": "🔄 Executions Over Time",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 16, "x": 0, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "rate(aura_workflow_executions_total[5m])", "legendFormat": "{{workflow}}" }
      ],
      "fieldConfig": {
        "defaults": { "custom": { "drawStyle": "line", "fillOpacity": 15 } }
      }
    },
    {
      "title": "📈 Success vs Failure Rate",
      "type": "piechart",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "increase(aura_workflow_success_total[24h])", "legendFormat": "Success" },
        { "expr": "increase(aura_workflow_errors_total[24h])", "legendFormat": "Failed" }
      ],
      "options": { "pieType": "donut", "legend": { "displayMode": "table", "placement": "right" } }
    },
    {
      "title": "⏱️ Execution Duration Distribution",
      "type": "histogram",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "rate(aura_workflow_duration_seconds_bucket[5m])", "legendFormat": "{{le}}" }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "title": "🏷️ Executions by Category",
      "type": "barchart",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "sum by(category) (increase(aura_workflow_executions_total[24h]))", "legendFormat": "{{category}}" }
      ],
      "fieldConfig": {
        "defaults": { "custom": { "drawStyle": "bars", "fillOpacity": 70 } }
      }
    },
    {
      "title": "🔝 Top Workflows by Executions",
      "type": "table",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 20 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "topk(10, sum by(workflow_name) (increase(aura_workflow_executions_total[24h])))",
          "legendFormat": "{{workflow_name}}",
          "format": "table",
          "instant": true
        }
      ],
      "transformations": [
        { "id": "organize", "options": { "renameByName": { "Value": "Executions" } } }
      ]
    }
  ],
  "refresh": "10s",
  "schemaVersion": 38,
  "style": "dark",
  "tags": ["aura-os", "workflows", "n8n"],
  "templating": { "list": [] },
  "time": { "from": "now-24h", "to": "now" },
  "timepicker": { "refresh_intervals": ["5s", "10s", "30s", "1m"] },
  "timezone": "Europe/Paris",
  "title": "AURA OS — Workflow Monitoring",
  "uid": "aura-workflows",
  "version": 1
}
